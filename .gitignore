node_modules/
/vendor/
.pnp/
.pnp.js

# ==============================================================================
# Build & Distribution Artifacts
# ==============================================================================
dist/
build/
out/
*.egg-info/
.next/

# ==============================================================================
# Environment Variables & Secrets (NEVER COMMIT THESE)
# ==============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# ==============================================================================
