.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ==============================================================================
# Logs, Diagnostic Data, and Caches
# ==============================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.cache/

# ==============================================================================
# Custom Exceptions (Negation)
# ==============================================================================
# Ignore all log files...
*.log
# ...but explicitly track this specific important log file
!important_activity.log
